# OCR provider selection: claude (default), deepseek, openai
OCR_PROVIDER=claude

# Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek via Anthropic-compatible API (https://platform.deepseek.com/)
# DEEPSEEK_API_KEY=sk-...

# OpenAI GPT-4o (https://platform.openai.com/) — requires: pip install openai
# OPENAI_API_KEY=sk-...
